# SARA - Environment Template
# Completar valores reales solo en .env.local (no versionado).

# GIT
GIT_REPO_URL=
GIT_MAIN_BRANCH=main
GIT_USER_NAME=
GIT_USER_EMAIL=

# SUPABASE
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_DB_URL=
# Regla DB: todos los objetos propios deben comenzar con "sara_".

# CHATWOOT
CHATWOOT_URL=
CHATWOOT_ACCOUNT_ID=6
CHATWOOT_INBOX_ID=44
CHATWOOT_CONVERSATION_ID=20
CHATWOOT_USER_TOKEN=
CHATWOOT_WEBHOOK_SECRET=

# VPS
VPS_HOST=
VPS_USER=root
VPS_PORT=22
VPS_DEPLOY_PATH=/opt/sara
VPS_SSH_PRIVATE_KEY_PATH=

# LLM
DEEPSEEK_API_KEY=
